[ext_resource type="Script" path="res://scripts/data/wave_data.gd" id="3_wave_data"]
[ext_resource type="Script" path="res://scripts/data/reward_pool_data.gd" id="4_reward_pool"]

[sub_resource type="Resource" id="Wave_1"]
script = ExtResource("3_wave_data")
spawn_turn = 1
lane = 0
enemy_unit_ids = Array[String](["enemy_servant"])
