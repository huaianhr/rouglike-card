starter_deck_ids = Array[String](["summon_knight", "summon_knight", "summon_knight", "summon_mage", "summon_mage", "power_up", "power_up", "undead_armor", "undead_armor", "summon_knight"])
reward_pool = SubResource("RewardPool_1")
total_turns = 10
